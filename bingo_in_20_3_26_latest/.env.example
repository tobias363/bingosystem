# ============================================================
# Bingo System — Environment Variables for Render Deployment
# ============================================================
# Copy this file to .env and fill in the values.
# On Render, set these as Environment Variables in the dashboard.

# --- Core ---
NODE_ENV=production
PORT=10000

# --- Session & Auth ---
SESSION_SECRET=change-me-to-random-secret
JWT_SECRET=change-me-to-random-jwt-secret
JWT_REFRESH_SECRET=change-me-to-random-refresh-secret

# --- MongoDB Atlas ---
# Use MONGO_URI for Atlas (mongodb+srv://...)
# OR use individual MONGO_* vars for self-hosted MongoDB
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/bingo_game?retryWrites=true&w=majority
DB_CONNECTION_TYPE=production
DB_MODE=production
# Individual vars (used if MONGO_URI is not set):
# MONGO_HOST=localhost
# MONGO_PORT=27017
# MONGO_USER=
# MONGO_PASSWORD=
# MONGO_DATABASE=bingo_game

# --- Redis (Render Redis or external) ---
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=0
REDIS_PREFIX=
REDIS_TLS=true

# --- MSSQL (OK Bingo / TicketService) ---
MSSQL_DB_SERVER=Ext.ticket.198.no
MSSQL_DB_DATABASE=TicketService
MSSQL_DB_PORT=14433
MSSQL_DB_USERNAME=Teknobingo
MSSQL_DB_PASSWORD=change-me

# --- Admin ---
DEFAULT_ADMIN_USER_LOGIN_EMAIL=admin@example.com
DEFAULT_ADMIN_USER_LOGIN_PASSWORD=change-me

# --- Verifone ---
VERIFONE_ENTITY_ID=
VERIFONE_CONTRACT_ID=
VERIFONE_USER_ID=
VERIFONE_API_ID=

# --- Metronia ---
METRONIA_API_URL=https://vpn2.byce.net:20056
METRONIA_API_TOKEN_TEST=

# --- IdKollen ---
IDKOLLEN_URL=https://api.idkollen.se/
IDKOLLEN_API_KEY=
IDKOLLEN_SECRET=

# --- Sveve SMS ---
SVEVE_USERNAME=
SVEVE_PASSWORD=
SVEVE_SENDER=

# --- Swedbank Pay ---
# Merchant credentials (from SwedbankPay merchant admin)
SWEDBANKPAY_PAYEE_ID=
SWEDBANKPAY_TOKEN=
SWEDBANKPAY_PAYEE_NAME=Spillorama
SWEDBANKPAY_PAYMENT_API_URL=https://api.payex.com
SWEDBANKPAY_PAYMENT_CURRENCY_CODE=NOK
# IMPORTANT: Update all URLs below to match your Render domain.
# For Render: replace <your-domain> with e.g. https://bingo-system-jsso.onrender.com
SWEDBANKPAY_HOST_URLS=["https://bingo-system-jsso.onrender.com"]
SWEDBANKPAY_PAYMENT_URL=https://bingo-system-jsso.onrender.com/payment/iframe
SWEDBANKPAY_COMPLETE_URL=https://bingo-system-jsso.onrender.com/payment/deposit/response
SWEDBANKPAY_CANCEL_URL=https://bingo-system-jsso.onrender.com/payment/deposit/response
SWEDBANKPAY_CALLBACK_URL=https://bingo-system-jsso.onrender.com/payment/webhook
SWEDBANKPAY_TERMS_OF_SERVICE_URL=

# --- Firebase ---
FIREBASE_ADMIN_DB_URL=

# --- SMTP ---
SMTP_EMAIL=
SMTP_PASSWORD=
