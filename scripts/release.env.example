# Copy this file to scripts/release.env and adjust values.

# Shared release metadata
CANDY_RELEASE_CHANNEL=staging
# CANDY_RELEASE_VERSION=20260305-120000-ab12cd3
# CANDY_RELEASE_COMMIT=ab12cd3

# Unity build
# Optional override. Hvis tom, forsøker scriptet å auto-detektere
# editorversjon fra Candy/ProjectSettings/ProjectVersion.txt.
# UNITY_BIN=/Applications/Unity/Hub/Editor/6000.3.10f1/Unity.app/Contents/MacOS/Unity
# UNITY_PROJECT_PATH=/Users/<you>/Projects/Bingo/Candy
CANDY_RUN_UNITY_COMPILE_CHECK=true
CANDY_RUN_THEME2_SMOKE=false

# Backend deploy (Render deploy hook)
# RENDER_DEPLOY_HOOK_URL=https://api.render.com/deploy/srv-...
# RENDER_DEPLOY_REQUIRE_HOOK=true
# RENDER_DEPLOY_WAIT_FOR_HEALTH=true
# RENDER_HEALTHCHECK_URL=https://bingosystem-3.onrender.com/admin/
# RENDER_DEPLOY_REQUIRE_HEALTHCHECK_URL=true
# RENDER_DEPLOY_WAIT_TIMEOUT_SECONDS=600
# RENDER_DEPLOY_POLL_INTERVAL_SECONDS=10
# RENDER_DEPLOY_CURL_RETRIES=3

# Candy publish mode
# CANDY_PUBLISH_MODE=none|local|rsync|s3
CANDY_PUBLISH_MODE=none
CANDY_PROMOTE_LIVE=false

# Local publish target
# CANDY_PUBLISH_LOCAL_DIR=/var/www/candy

# Rsync publish target
# Supports placeholders: {channel}, {release}
# CANDY_PUBLISH_RSYNC_TARGET=deploy@host:/var/www/candy/{channel}/releases/{release}/
# Optional live alias target used when CANDY_PROMOTE_LIVE=true
# CANDY_PUBLISH_RSYNC_LIVE_TARGET=deploy@host:/var/www/candy/{channel}/current/

# S3 publish target
# CANDY_PUBLISH_S3_BUCKET=my-candy-bucket
# CANDY_PUBLISH_S3_PREFIX=candy
# CANDY_CLOUDFRONT_DISTRIBUTION_ID=E123456789

# release-all toggles
# RUN_BACKEND_CHECK=true
# RUN_ROOT_CHECK_ALL=false
# RUN_BACKEND_DEPLOY=true
# RUN_CANDY_RELEASE=true
