# Copy this file to scripts/release.env and adjust values.

# Shared release metadata
SYSTEM_RELEASE_CHANNEL=staging
# SYSTEM_RELEASE_VERSION=20260305-120000-ab12cd3
# SYSTEM_RELEASE_COMMIT=ab12cd3

# Backend deploy (Render deploy hook)
# RENDER_DEPLOY_HOOK_URL=https://api.render.com/deploy/srv-...
# RENDER_DEPLOY_REQUIRE_HOOK=true
# RENDER_DEPLOY_WAIT_FOR_HEALTH=true
# RENDER_HEALTHCHECK_URL=https://spillorama-system.onrender.com/admin/
# RENDER_DEPLOY_REQUIRE_HEALTHCHECK_URL=true
# RENDER_DEPLOY_WAIT_TIMEOUT_SECONDS=600
# RENDER_DEPLOY_POLL_INTERVAL_SECONDS=10
# RENDER_DEPLOY_CURL_RETRIES=3

# release-all toggles
# RUN_BACKEND_CHECK=true
# RUN_ROOT_CHECK_ALL=false
# RUN_BACKEND_DEPLOY=true
