# === Bingo System - Local Development Release Config ===

# Release channel
CANDY_RELEASE_CHANNEL=staging

# Unity build - auto-detects from ProjectVersion.txt
# Candy uses 6000.3.10f1 (installed)
# Spillorama uses 6000.0.58f2 (must be installed via Unity Hub)
CANDY_RUN_UNITY_COMPILE_CHECK=true
CANDY_RUN_THEME2_SMOKE=false

# Publish mode - local for dev
CANDY_PUBLISH_MODE=local
CANDY_PUBLISH_LOCAL_DIR=/Users/tobiashaugen/Projects/Bingo-system/bingo_in_20_3_26_latest/backend/public/candy
CANDY_PROMOTE_LIVE=false

# Render deploy (fill in when ready to deploy)
# RENDER_DEPLOY_HOOK_URL=
# RENDER_HEALTHCHECK_URL=
