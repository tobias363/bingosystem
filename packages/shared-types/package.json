{
  "name": "@spillorama/shared-types",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./game": {
      "types": "./src/game.ts",
      "import": "./dist/game.js"
    },
    "./socket-events": {
      "types": "./src/socket-events.ts",
      "import": "./dist/socket-events.js"
    },
    "./api": {
      "types": "./src/api.ts",
      "import": "./dist/api.js"
    },
    "./spill1-patterns": {
      "types": "./src/spill1-patterns.ts",
      "import": "./dist/spill1-patterns.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "tsx --test \"__tests__/**/*.test.ts\"",
    "schema:export": "tsx scripts/export-json-schemas.ts"
  },
  "devDependencies": {
    "tsx": "^4.19.3",
    "typescript": "~5.8.2"
  },
  "dependencies": {
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.2"
  }
}
