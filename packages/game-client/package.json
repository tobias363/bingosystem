{
  "name": "@spillorama/game-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && vite build --config vite.preview.config.ts && vite build --config vite.visual-harness.config.ts",
    "build:visual-harness": "tsc && vite build && vite build --config vite.visual-harness.config.ts",
    "preview": "vite preview",
    "serve:visual-harness": "node ../../scripts/serve-visual-harness.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@sentry/browser": "^8.48.0",
    "@spillorama/shared-types": "*",
    "gsap": "^3.12.7",
    "howler": "^2.2.4",
    "i18next": "^24.2.2",
    "pixi.js": "^8.6.6",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@types/howler": "^2.2.12",
    "happy-dom": "^20.9.0",
    "typescript": "~5.8.2",
    "vite": "^6.3.2",
    "vitest": "^3.1.1"
  }
}
