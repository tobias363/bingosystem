# Wallet provider: file | http | postgres
WALLET_PROVIDER=file

# Platform/auth database (required for login/game-catalog/session)
# Falls back to WALLET_PG_CONNECTION_STRING when empty, but set this explicitly in production.
APP_PG_CONNECTION_STRING=
# Optional schema, default public
APP_PG_SCHEMA=public
# Session lifetime in hours
AUTH_SESSION_TTL_HOURS=168

# Shared
WALLET_DEFAULT_INITIAL_BALANCE=1000

# Compliance baseline (databingo/hovedspill limits)
BINGO_MIN_ROUND_INTERVAL_MS=30000
BINGO_DAILY_LOSS_LIMIT=900
BINGO_MONTHLY_LOSS_LIMIT=4400
BINGO_PLAY_SESSION_LIMIT_MS=3600000
BINGO_PAUSE_DURATION_MS=300000

# Auto round scheduler
# Production guard: autoplay er av i production med mindre denne settes til true.
BINGO_ALLOW_AUTOPLAY_IN_PRODUCTION=false
AUTO_ROUND_START_ENABLED=true
AUTO_ROUND_START_INTERVAL_MS=30000
AUTO_ROUND_MIN_PLAYERS=1
AUTO_ROUND_TICKETS_PER_PLAYER=4
AUTO_ROUND_ENTRY_FEE=0
# RTP cap for bingo payouts (0-100)
BINGO_PAYOUT_PERCENT=100
BINGO_SINGLE_ACTIVE_ROOM_PER_HALL=true

# Optional auto draw (server draws numbers automatically while game is running)
AUTO_DRAW_ENABLED=true
AUTO_DRAW_INTERVAL_MS=1200
AUTO_ROUND_SCHEDULER_TICK_MS=250

# File provider (used when WALLET_PROVIDER=file)
# Absolute path or path relative to project root.
WALLET_DATA_PATH=backend/data/wallets.json

# HTTP provider (used when WALLET_PROVIDER=http)
# Example: https://wallet.example.com
WALLET_API_BASE_URL=
# Example: /api or /v1
WALLET_API_PREFIX=/api
# Optional bearer token
WALLET_API_KEY=
# Timeout in ms
WALLET_API_TIMEOUT_MS=8000

# Postgres provider (used when WALLET_PROVIDER=postgres)
# Example: postgres://postgres:postgres@localhost:5432/bingo
WALLET_PG_CONNECTION_STRING=
# Optional schema, default public
WALLET_PG_SCHEMA=public
# Optional SSL toggle: true/false
WALLET_PG_SSL=false

# Swedbank Pay (top-up intent + callback + confirm)
# Test API base:
SWEDBANK_PAY_API_BASE_URL=https://api.externalintegration.payex.com
# Merchant credentials
SWEDBANK_PAY_ACCESS_TOKEN=
SWEDBANK_PAY_PAYEE_ID=
SWEDBANK_PAY_PAYEE_NAME=
# Checkout config
SWEDBANK_PAY_PRODUCT_NAME=Checkout3
SWEDBANK_PAY_CURRENCY=NOK
SWEDBANK_PAY_LANGUAGE=nb-NO
# Public base URL for your app (used to derive complete/cancel/callback URLs)
# For Render: https://spillorama-system.onrender.com/
SWEDBANK_PAY_MERCHANT_BASE_URL=https://spillorama-system.onrender.com/
# Optional explicit URLs (override derived URLs from merchant base URL)
SWEDBANK_PAY_CALLBACK_URL=
SWEDBANK_PAY_COMPLETE_URL=
SWEDBANK_PAY_CANCEL_URL=
SWEDBANK_PAY_TERMS_URL=
# Timeout in ms
SWEDBANK_PAY_REQUEST_TIMEOUT_MS=10000

# --- External game integration (Candy) ---
# API key that demo-backend uses to call /api/ext-wallet/* endpoints
EXT_GAME_WALLET_API_KEY=
# Candy demo-backend URL for launch requests
CANDY_BACKEND_URL=https://candy-backend-ldvg.onrender.com
# API key for calling demo-backend's /api/integration/launch
CANDY_INTEGRATION_API_KEY=
