{
  "name": "bingo-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:single": "bash scripts/dev-single.sh",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "check": "tsc --noEmit",
    "test": "BINGO_RTP_TELEMETRY_LOGS=false tsx --test src/**/*.test.ts",
    "test:compliance": "BINGO_RTP_TELEMETRY_LOGS=false tsx --test src/compliance/**/*.test.ts",
    "sim:rtp-near-miss": "tsx src/compliance/rtp-near-miss-simulation.ts",
    "check:rtp-near-miss": "BINGO_RTP_TELEMETRY_LOGS=false tsx src/compliance/rtp-near-miss-simulation.ts --rounds=500 --targets=80 --windowSize=500 --entryFee=100 --no-near-miss-gate && BINGO_RTP_TELEMETRY_LOGS=false tsx src/compliance/rtp-near-miss-simulation.ts --rounds=500 --targets=80 --windowSize=500 --entryFee=100 --no-force-host-win --no-rtp-gate"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "pg": "^8.16.3",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.14",
    "@types/pg": "^8.15.5",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
