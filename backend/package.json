{
  "name": "bingo-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:single": "bash scripts/dev-single.sh",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "check": "tsc --noEmit",
    "test": "tsx --test src/**/*.test.ts",
    "test:compliance": "tsx --test src/compliance/**/*.test.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "ioredis": "^5.10.1",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.14",
    "@types/pg": "^8.15.5",
    "artillery": "^2.0.30",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
