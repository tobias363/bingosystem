{
  "name": "bingo-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:single": "bash scripts/dev-single.sh",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "check": "tsc --noEmit",
    "test": "LOG_LEVEL=warn tsx --test 'src/**/*.test.ts'",
    "test:compliance": "tsx --test 'src/compliance/**/*.test.ts'",
    "migrate": "node-pg-migrate -d APP_PG_CONNECTION_STRING -m migrations --ignore-pattern '.*\\.md$|^\\..*' up",
    "migrate:create": "node-pg-migrate -d APP_PG_CONNECTION_STRING -m migrations --ignore-pattern '.*\\.md$|^\\..*' create",
    "seed:test-users": "tsx scripts/seed-test-users-hall.ts",
    "seed:demo-tv-bonus": "tsx scripts/seed-demo-tv-and-bonus.ts",
    "seed:demo-tv-minimal": "tsx scripts/seed-demo-tv-minimal.ts",
    "import:legacy-templates": "tsx scripts/import-legacy-subgame-templates.ts",
    "spec:lint": "redocly lint openapi.yaml"
  },
  "dependencies": {
    "@sentry/node": "^10.49.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@spillorama/shared-types": "file:../../packages/shared-types",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "firebase-admin": "^12.7.0",
    "ioredis": "^5.10.1",
    "mssql": "^12.3.1",
    "nodemailer": "^8.0.5",
    "pdfkit": "^0.17.2",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "socket.io": "^4.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@redocly/cli": "^2.28.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/mssql": "^12.3.0",
    "@types/node": "^22.13.14",
    "@types/nodemailer": "^7.0.2",
    "@types/pdfkit": "^0.17.3",
    "@types/pg": "^8.15.5",
    "artillery": "^2.0.30",
    "fast-check": "^4.7.0",
    "node-pg-migrate": "^8.0.4",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.19.3",
    "typescript": "~5.9.0",
    "yaml": "^2.8.3"
  }
}
